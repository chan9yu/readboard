{
	"mcpServers": {
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": ["@playwright/mcp@latest"],
			"env": {}
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"sequential-thinking": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
		},
		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		},
		"shrimp-task-manager": {
			"command": "node",
			"args": ["/Users/changyu/Base/@local-mcp/mcp-shrimp-task-manager/dist/index.js"],
			"env": {
				"DATA_DIR": "/Users/changyu/Base/inflearn/invoice/.shrimp_data",
				"TEMPLATES_USE": "ko",
				"ENABLE_GUI": "true"
			}
		}
	}
}
